msgid "Start Rescuezilla"
msgstr "Iniciar Rescuezilla"

msgid "If boot fails, reboot and try selecting Graphical fallback instead"
msgstr "Se a inicialização falhar, reinicie e selecione o Modo - Fallback Gráfico"

msgid "Graphical fallback mode"
msgstr "Modo - Fallback Gráfico"

msgid "Use low-resolution fallback graphics driver if standard mode doesn't work for your hardware"
msgstr "Utilize um driver gráfico de baixa resolução se o modo padrão não funcionar em seu hardware"

msgid "Load USB into RAM"
msgstr "Carregar USB na RAM"

msgid "Loads Rescuezilla into memory allowing the boot media to be ejected after bootup"
msgstr "Carrega o Rescuezilla na memória, permitindo que a mídia de inicialização seja ejetada após a inicialização"

msgid "Check USB for defects"
msgstr "Verificar USB por defeitos"

msgid "Verify integrity of USB drive"
msgstr "Verificar a integridade da unidade USB"

msgid "Enter BIOS Setup"
msgstr "Entrar na configuração do BIOS"

msgid "Configure machine's firmware, boot options etc"
msgstr "Configurar o firmware da máquina, opções de inicialização e etc"

msgid "Memory test"
msgstr "Teste de memória"

msgid "Check computer memory for errors"
msgstr "Verificar se há erros na memória do computador"
